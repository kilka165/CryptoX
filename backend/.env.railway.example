# ── Переменные окружения для Railway (Service → Variables) ──
# Скопируйте эти ключи в Railway. Значения <...> замените на свои.

APP_NAME=CryptoX
APP_ENV=production
APP_DEBUG=false
# APP_KEY: сгенерируйте локально командой `php artisan key:generate --show`
# и вставьте сюда целиком (вместе с префиксом base64:).
APP_KEY=
APP_URL=https://<your-backend>.up.railway.app

# База данных — ссылка на Postgres-сервис Railway (см. инструкцию).
DB_CONNECTION=pgsql
DB_URL=${{Postgres.DATABASE_URL}}

# Для демо держим всё синхронно/в БД, фоновых воркеров на Railway нет.
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=sync

# Логи — в stderr, чтобы видеть их в Railway → Deployments → Logs.
LOG_CHANNEL=stderr
LOG_LEVEL=error

# Домен фронта на Vercel — для CORS (см. config/cors.php).
FRONTEND_URL=https://<your-frontend>.vercel.app

# Если используете приватные ключи Binance — добавьте их тоже:
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
